# Скопируйте этот файл в .env и вставьте свой токен
BOT_TOKEN=your_bot_token_here
YANDEX_DICT_API_KEY=your_yandex_api_key_here

# ========== ЗАЩИТА ОТ ЗЛОУПОТРЕБЛЕНИЙ ==========

# Rate limiting (ограничение частоты запросов)
RATE_LIMIT_MESSAGES=10  # максимум сообщений
RATE_LIMIT_SECONDS=60   # за N секунд

# Лимит слов на пользователя
MAX_WORDS_PER_USER=1000

# Белый список user_id (пусто = все могут использовать)
# ALLOWED_USERS=123456,789012,345678

# Чёрный список user_id (заблокированные пользователи)
# BANNED_USERS=111111,222222

# Максимальная длина слова для поиска
MAX_WORD_LENGTH=50
